{
  "entities": {
    "UserAccount": {
      "title": "UserAccount",
      "description": "User profile and balance details",
      "type": "object",
      "properties": {
        "username": { "type": "string" },
        "phone": { "type": "string" },
        "bankName": { "type": "string" },
        "realName": { "type": "string" },
        "bankAccount": { "type": "string" },
        "passwordHash": { "type": "string" },
        "transactionPassword": { "type": "string" },
        "role": { "type": "string" },
        "balance": { "type": "number" },
        "commission": { "type": "number" },
        "frozen": { "type": "number" },
        "ordersCompleted": { "type": "number" },
        "level": { "type": "number" },
        "isBlocked": { "type": "boolean" },
        "isBanned": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "invitationCode": { "type": "string" },
        "accountCategory": { "type": "string" },
        "country": { "type": "string" },
        "latestDepositAmount": { "type": "number" }
      },
      "required": ["username", "phone", "passwordHash", "role", "balance", "commission", "frozen", "ordersCompleted", "level", "isBlocked", "createdAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Deposit and withdrawal requests",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "phone": { "type": "string" },
        "username": { "type": "string" },
        "type": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string" },
        "note": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "phone", "username", "type", "amount", "status", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "Products available in the store",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "price": { "type": "number" },
        "originalPrice": { "type": "number" },
        "discount": { "type": "string" },
        "salesText": { "type": "string" },
        "image": { "type": "string" },
        "deliveryTime": { "type": "string" },
        "location": { "type": "string" },
        "isLive": { "type": "boolean" },
        "rating": { "type": "number" },
        "reviewsCount": { "type": "number" },
        "description": { "type": "string" },
        "shopName": { "type": "string" },
        "variants": { "type": "array", "items": { "type": "string" } },
        "isHot": { "type": "boolean" },
        "isMall": { "type": "boolean" }
      },
      "required": ["id", "title", "price", "originalPrice", "discount", "image"]
    },
    "MatchRequest": {
      "title": "MatchRequest",
      "description": "Order match requests generated by users",
      "type": "object",
      "properties": {
        "phone": { "type": "string" },
        "username": { "type": "string" },
        "status": { "type": "string" },
        "assignedProduct": { "type": "object" },
        "timestamp": { "type": "number" }
      },
      "required": ["phone", "username", "status", "timestamp"]
    },
    "SystemSettings": {
      "title": "SystemSettings",
      "description": "App branding and settings",
      "type": "object",
      "properties": {
        "siteName": { "type": "string" },
        "siteLogo": { "type": "string" },
        "siteIcon": { "type": "string" },
        "themeColor": { "type": "string" },
        "slides": { "type": "array" }
      },
      "required": ["siteName", "siteLogo", "themeColor"]
    }
  },
  "firestore": {
    "users/{phone}": {
      "schema": "UserAccount",
      "description": "User profiles indexed by phone number"
    },
    "transactions/{txId}": {
      "schema": "Transaction",
      "description": "Financial deposit and withdrawal transactions"
    },
    "products/{prodId}": {
      "schema": "Product",
      "description": "Products available on the site"
    },
    "activity_products/{prodId}": {
      "schema": "Product",
      "description": "Activity products available on the site"
    },
    "match_requests/{phone}": {
      "schema": "MatchRequest",
      "description": "Order matching request queue"
    },
    "shopee_settings/global": {
      "schema": "SystemSettings",
      "description": "Global branding and slides settings"
    }
  }
}
